MarketExtension/Assets/SmallTile.png
MarketExtension/Assets/SplashScreen.png
MarketExtension/Assets/Square150x150Logo.png
MarketExtension/Assets/Wide310x150Logo.png

# NuGet packages (restored on build)
*.nupkg
*.snupkg
packages/
.nuget/

# Visual Studio
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates
*.userprefs

# Publish profiles (contain machine-specific paths)
**/Properties/PublishProfiles/

# MSIX / AppX packaging output
AppPackages/
BundleArtifacts/
*.msix
*.msixbundle
*.appx
*.appxbundle
*.appxupload

# Generated CsWinRT interop files
Generated Files/
_Generated/

# Rider / JetBrains
.idea/
*.DotSettings.user

# ReSharper
_ReSharper*/
*.ReSharper

# NCrunch
*.ncrunch*
.*crunch*.local.xml

